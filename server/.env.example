server=localhost
schema=dbo
database=your_database_name
user=your_database_user
password=your_database_password
# Optional roster DB override. If you mount a separate secret directory, keep file names as:
# server, database, user, password, schema
ROSTER_SECRET_DIR=
# Optional env-based alternative if you do not mount the roster secret as files.
ROSTER_SERVER=
ROSTER_SCHEMA=dbo
ROSTER_DATABASE=
ROSTER_USER=
ROSTER_PASSWORD=
# Optional Keycloak/OIDC identity settings.
# The app will use employeeid from the token/header and try both NetworkID and MyID in roster lookup.
KEYCLOAK_ISSUER_URL=
KEYCLOAK_INTROSPECTION_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Leave this true for local dev if you want the N35589 fallback when no identity is forwarded.
ALLOW_HARDCODED_IDENTITY_FALLBACK=true
# Dev binds to localhost. Production containers bind to 0.0.0.0 automatically.
API_PORT=3002
PORT=8080
# Optional SQL cache schedule for deployed dashboards.
SQL_DATASET_CACHE_TIMEZONE=America/New_York
SQL_DATASET_CACHE_REFRESH_HOUR=5
SQL_DATASET_CACHE_REFRESH_MINUTE=0
