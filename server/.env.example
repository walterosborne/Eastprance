server=localhost
schema=dbo
database=your_database_name
user=your_database_user
password=your_database_password
# Dev binds to localhost. Production containers bind to 0.0.0.0 automatically.
API_PORT=3002
PORT=8080
# Optional SQL cache schedule for deployed dashboards.
SQL_DATASET_CACHE_TIMEZONE=America/New_York
SQL_DATASET_CACHE_REFRESH_HOUR=5
SQL_DATASET_CACHE_REFRESH_MINUTE=0
